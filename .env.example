NEXT_PUBLIC_ALCHEMY_API_KEY=<ALCHEMY_KEY>
NEXT_PUBLIC_TARGET_NETWORK=Sepolia
NEXT_PUBLIC_API_URL=<API>

NEXT_PUBLIC_TOKENS_LIST_URL=https://tokens.1inch.eth.link
NEXT_PUBLIC_TOKENS_IMG_HOSTNAME=tokens.1inch.io

NEXT_PUBLIC_GIT_WILDCAT_URL=https://github.com/wildcat-finance/wildcat-app-v2/commit

# Logging
LOG_LEVEL=info
NEXT_PUBLIC_LOG_LEVEL=info

# otel
# Set to true in preview/prod to enable tracing (will default to false if not set)
OTEL_ENABLED=false
NEXT_PUBLIC_OTEL_EXPORTER_OTLP_ENDPOINT=/api/otel
NEXT_PUBLIC_OTEL_SERVICE_NAME=wildcat-app-v2
NEXT_PUBLIC_OTEL_SERVICE_NAMESPACE=wildcat-application-group
NEXT_PUBLIC_OTEL_DEPLOYMENT_ENVIRONMENT=dev
OTEL_EXPORTER_OTLP_ENDPOINT=https://localhost/otlp
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=wildcat-app-v2
OTEL_SERVICE_NAMESPACE=wildcat-application-group
OTEL_DEPLOYMENT_ENVIRONMENT=dev
OTEL_RELAY_ALLOWED_ORIGINS=http://localhost:3000
OTEL_RELAY_MAX_BODY_BYTES=1048576
OTEL_RELAY_TIMEOUT_MS=5000
OTEL_RELAY_RATE_LIMIT_MAX=120
OTEL_RELAY_RATE_LIMIT_WINDOW_MS=60000
OTEL_RELAY_UPSTREAM_AUTH_HEADER=authorization
OTEL_RELAY_UPSTREAM_AUTH_VALUE=Bearer <COLLECTOR_TOKEN>

# slack bug reports
SLACK_BOT_TOKEN=<token>
SLACK_BUG_REPORT_CHANNEL=#app-bug-reports
SLACK_BUG_REPORT_GRAFANA_BASE_URL=https://<domain>.grafana.net
SLACK_BUG_REPORT_GRAFANA_DATASOURCE_UID=<datasource-uid>

# For local wildcat-sdk package testing
# Use together with /scripts/reinstall-wildcat-sdk.sh
# WILDCAT_SDK_PATH=/Users/wildcat/wildcat/wildcat.ts/wildcatfi-wildcat-sdk-3.0.39.tgz
