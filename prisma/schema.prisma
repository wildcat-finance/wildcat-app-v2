generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AccountKind {
  EOA
  GnosisSafe
  OtherContract
}

enum SignatureKind {
  // Signature from the target account (e.g. borrower)
  ECDSA
  // Signature from the gnosis safe
  GnosisSignature
  // ECDSA signature from a single owner of the gnosis safe
  GnosisOwnerECDSA
  // Non-Gnosis EIP-1271 contract signature
  EIP1271
}

enum ServiceAgreementParty {
  Borrower
  Lender
}

// @todo - need to make the borrower/lender signatures distinct as the borrower
// can technically also be a lender, but that would use a different message

model MlaSignature {
  kind        SignatureKind
  address     String
  // If the signature is from a single owner of a gnosis safe, this is the address of the
  // owner that made the signature; otherwise, it's the same as `address`
  signer      String
  signature   String
  // The block number at which the signature was verified - only relevant for non-EOA signatures
  blockNumber Int?
  // The chain ID and market address of the master loan agreement that this signature is for
  chainId     Int
  market      String

  timeSigned DateTime

  // Relation to the master loan agreement
  mla MasterLoanAgreement @relation("MlaSignatureToMasterLoanAgreement", fields: [chainId, market], references: [chainId, market])

  @@id([chainId, market, signer])
}

model RefusalToAssignMla {
  chainId     Int
  // The market address
  market      String
  // The address of the borrower
  address     String
  // The address of the signer declining the MLA
  signer      String
  // The signature of the borrower declining the MLA
  signature   String
  timeSigned  DateTime
  // The block number at which the signature was verified - only relevant for non-EOA signatures
  blockNumber Int?
  kind        SignatureKind

  acknowledgements NonMlaAcknowledgement[] @relation("RefusalToAssignMlaToNonMlaAcknowledgement")

  @@id([chainId, market])
}

model NonMlaAcknowledgement {
  chainId                    Int
  // The market address
  market                     String
  // The lender address
  address                    String
  // If the signature is from a single owner of a gnosis safe, this is the address of the
  // owner that made the signature; otherwise, it's the same as `address`
  signer                     String
  signature                  String
  kind                       SignatureKind
  // The block number at which the signature was verified - only relevant for non-EOA signatures
  blockNumber                Int?
  acknowledgementTextVersion String
  acknowledgementText        String
  timeSigned                 DateTime      @default(now())
  createdAt                  DateTime      @default(now())

  refusal RefusalToAssignMla @relation("RefusalToAssignMlaToNonMlaAcknowledgement", fields: [chainId, market], references: [chainId, market], onDelete: Cascade)

  @@id([chainId, market, address, acknowledgementTextVersion])
  @@index([chainId, address])
}

model AdminAccount {
  id      Int    @id @default(autoincrement())
  chainId Int
  address String

  @@unique([chainId, address])
}


model MlaTemplate {
  id             Int      @id @default(autoincrement())
  chainId        Int
  name           String
  description    String?
  hide           Boolean? @default(false)
  isDefault      Boolean?
  html           String
  plaintext      String
  borrowerFields Json
  lenderFields   Json

  mlas MasterLoanAgreement[] @relation("MlaTemplateToMasterLoanAgreement")

  @@unique([chainId, id])
}


model MasterLoanAgreement {
  chainId        Int
  market         String
  borrower       String
  html           String
  plaintext      String
  templateId     Int
  lenderFields   Json
  mlaSignatureId Int?

  borrowerProfile Borrower @relation("BorrowerToMasterLoanAgreement", fields: [chainId, borrower], references: [chainId, address])

  template      MlaTemplate    @relation("MlaTemplateToMasterLoanAgreement", fields: [chainId, templateId], references: [chainId, id])
  mlaSignatures MlaSignature[] @relation("MlaSignatureToMasterLoanAgreement")

  // market must be unique
  @@id([chainId, market])
}

model LenderServiceAgreementSignature {
  chainId              Int
  signer               String
  signature            String
  timeSigned           DateTime
  serviceAgreementHash String

  @@id([chainId, signer, serviceAgreementHash])
}

model BorrowerServiceAgreementSignature {
  chainId              Int
  address              String
  signature            String
  timeSigned           DateTime
  borrowerName         String
  serviceAgreementHash String

  borrower Borrower @relation("BorrowerToServiceAgreementSignature", fields: [chainId, address], references: [chainId, address], onDelete: Cascade)

  @@id([chainId, address])
}

// One immutable ToU version. Global, not chain-scoped.
model ServiceAgreement {
  id                  Int      @id @default(autoincrement())
  version             String
  plaintext           String
  html                String
  plaintextSha256     String   @unique // bare lowercase SHA-256 hex of plaintext
  legacyWrapperHash   String?  @unique // 0x-prefixed keccak256 of the signed wrapper
  acknowledgementText String   // exact wrapper body, no Date / Organization Name lines
  effectiveDate       DateTime
  isCurrent           Boolean  @default(false)
  createdAt           DateTime @default(now())

  signatures ServiceAgreementSignature[]
}

// One ToU acceptance. Chain-scoped, serves both parties.
// No FK to Borrower: borrower deletion must delete these rows explicitly.
model ServiceAgreementSignature {
  id                 Int                   @id @default(autoincrement())
  chainId            Int
  address            String
  // If the signature is from a single owner of a gnosis safe, this is the address of the
  // owner that made the signature; otherwise, it's the same as `address`
  signer             String
  party              ServiceAgreementParty
  serviceAgreementId Int
  signature          String
  // NULL for backfilled legacy rows; always set for new rows
  kind               SignatureKind?
  // The block number at which the signature was verified - only relevant for non-EOA signatures
  blockNumber        Int?
  timeSigned         DateTime
  organizationName   String?
  // Exact signed message for new rows; reconstructed (or NULL) for legacy rows
  signedMessage      String?
  createdAt          DateTime              @default(now())

  serviceAgreement ServiceAgreement @relation(fields: [serviceAgreementId], references: [id])

  @@unique([chainId, address, party, serviceAgreementId])
  @@index([serviceAgreementId])
}

model BorrowerInvitation {
  id              Int      @id @default(autoincrement())
  chainId         Int
  address         String
  name            String
  alias           String?
  inviter         String
  description     String?
  founded         String?
  headquarters    String?
  jurisdiction    String?
  physicalAddress String?
  entityKind      String?
  timeInvited     DateTime

  borrower Borrower @relation("BorrowerToInvitation", fields: [chainId, address], references: [chainId, address], onDelete: Cascade)

  @@unique([chainId, address])
}

model Borrower {
  chainId Int
  address String

  name              String?
  alias             String?
  avatar            String?
  description       String?
  founded           String?
  headquarters      String?
  website           String?
  twitter           String?
  telegram          String?
  linkedin          String?
  email             String?
  jurisdiction      String?
  physicalAddress   String?
  entityKind        String?
  additionalUrls    Json?
  registeredOnChain Boolean
  // Raw `from` of the tx that emitted BorrowerAdded; may be a Safe executor/relayer.
  // NULL = not yet resolved.
  registeredBy      String?

  invitation                BorrowerInvitation?                @relation("BorrowerToInvitation")
  serviceAgreementSignature BorrowerServiceAgreementSignature? @relation("BorrowerToServiceAgreementSignature")
  updates                   BorrowerProfileUpdateRequest[]     @relation("BorrowerToProfileUpdateRequest")
  mlas                      MasterLoanAgreement[]              @relation("BorrowerToMasterLoanAgreement")

  @@unique([chainId, address])
}

model BorrowerProfileUpdateRequest {
  id        Int      @id @default(autoincrement())
  chainId   Int
  address   String
  createdAt DateTime

  name            String?
  alias           String?
  avatar          String?
  description     String?
  founded         String?
  headquarters    String?
  website         String?
  twitter         String?
  telegram        String?
  linkedin        String?
  email           String?
  jurisdiction    String?
  physicalAddress String?
  entityKind      String?
  additionalUrls  Json?

  acceptedAt     DateTime?
  rejectedAt     DateTime?
  rejectedReason String?

  borrowerProfile Borrower @relation("BorrowerToProfileUpdateRequest", fields: [chainId, address], references: [chainId, address], onDelete: Cascade)

  @@index([chainId, address])
}

model MarketDescription {
  chainId Int
  marketAddress String
  description String

  @@unique([chainId, marketAddress])
}
